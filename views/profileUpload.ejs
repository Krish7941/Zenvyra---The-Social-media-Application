<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Profile Pic — Threadline</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --border: rgba(255, 255, 255, 0.07);
            --accent: #fcff47;
            --accent2: #ff6b47;
            --text: #f0ede8;
            --muted: #6b6878;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            margin: 100px 100px;
            padding : 0 20vw;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            margin: auto;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 40px 30px;
            animation: fadeUp 0.5s ease both;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        form {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .header {
            text-align: center;
            margin-bottom: 24px;
        }

        .header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 10px;
            padding-bottom: 5px;
        }

        .upload-box {
            width: 420px;
            height: 220px;

            margin: 25px auto;
            /* center */
            border: 2px dashed var(--border);
            border-radius: 14px;

            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;

            cursor: pointer;
            transition: all 0.25s ease;
            position: relative;
        }

        .upload-box:hover {
            border-color: var(--accent);
            background: rgba(252, 255, 71, 0.05);
        }

        .preview {
            margin-top: 20px;
            display: flex;
            justify-content: center;
        }

        .preview img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
        }

        .submit-btn {
            width: 50%;
            margin-top: 20px;
            padding: 14px;
            background: var(--accent);
            color: #000;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(252, 255, 71, 0.3);
        }

        .back {
            text-align: center;
            margin-top: 16px;
            font-size: 13px;
        }

        .back a {
            color: var(--accent);
            text-decoration: none;
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="header">
            <h2>Upload Profile Pic</h2>
            <p>Make your profile stand out ✨</p>
        </div>

        <form action="/upload" method="post" enctype="multipart/form-data">

            <label class="upload-box text-center flex flex-col items-center justify-center">
                Click to upload image<br>
                <input type="file" name="image" id="fileInput" hidden required>
            </label>

            <!-- <div class="preview" id="preview"></div> -->

            <button type="submit" class="submit-btn">Upload →</button>
        </form>

        <div class="back">
            <a href="/profile">← Back to Profile</a>
        </div>

    </div>

</body>

</html>