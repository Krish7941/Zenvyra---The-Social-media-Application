<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zenvyra — Your Feed</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --surface2: #18181f;
            --border: rgba(255, 255, 255, 0.07);
            --accent: #fcff47;
            --accent2: #ff6b47;
            --text: #f0ede8;
            --muted: #6b6878;
            --input-bg: rgba(255, 255, 255, 0.04);
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
        }

        /* ── NAVBAR ── */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            height: 64px;
            background: rgba(10, 10, 15, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--text);
        }

        .nav-dot {
            width: 28px;
            height: 28px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .nav-name {
            font-family: 'Playfair Display', serif;
            font-size: 19px;
            font-weight: 700;
        }

        .nav-center {
            display: flex;
            gap: 4px;
        }

        .nav-link {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s, background 0.2s;
        }

        .nav-link:hover,
        .nav-link.active {
            color: var(--text);
            background: rgba(255, 255, 255, 0.06);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: #0a0a0f;
            cursor: pointer;
            object-fit: cover;
            overflow: hidden;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--muted);
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            color: #ff6b6b;
            border-color: rgba(255, 107, 107, 0.3);
            background: rgba(255, 107, 107, 0.06);
        }

        /* ── MAIN ── */
        .main {
            max-width: 1100px;
            margin: 0 auto;
            padding: 48px 40px;
        }

        /* ── COMPOSE ── */
        .compose-section {
            margin-bottom: 56px;
            animation: fadeUp 0.5s ease both;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .compose-header {
            margin-bottom: 20px;
        }

        .compose-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 38px;
            font-weight: 900;
            letter-spacing: -1.5px;
            line-height: 1.1;
        }

        .compose-header h1 span {
            color: var(--accent);
        }

        .compose-header p {
            font-size: 14px;
            color: var(--muted);
            margin-top: 6px;
        }

        .compose-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            transition: border-color 0.2s;
        }

        .compose-card:focus-within {
            border-color: rgba(232, 255, 71, 0.3);
        }

        .compose-top {
            display: flex;
            gap: 16px;
            margin-bottom: 16px;
        }

        .compose-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: #0a0a0f;
            flex-shrink: 0;
            margin-top: 4px;
        }

        .compose-card textarea {
            flex: 1;
            background: none;
            border: none;
            outline: none;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 16px;
            line-height: 1.6;
            resize: none;
            width: 100%;
            min-height: 90px;
        }

        .compose-card textarea::placeholder {
            color: var(--muted);
        }

        .compose-bottom {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 16px;
            border-top: 1px solid var(--border);
        }

        .compose-meta {
            font-size: 12px;
            color: var(--muted);
        }

        .post-btn {
            padding: 10px 24px;
            background: var(--accent);
            color: #0a0a0f;
            border: none;
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s;
        }

        .post-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(255, 249, 71, 0.25);
        }

        /* ── POSTS SECTION ── */
        .posts-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
        }

        .posts-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 700;
        }

        .posts-count {
            font-size: 13px;
            color: var(--muted);
            background: rgba(255, 255, 255, 0.05);
            padding: 5px 12px;
            border-radius: 20px;
        }

        /* ── POST GRID ── */
        .posts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px;
        }

        .post-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
            animation: fadeUp 0.5s ease both;
        }

        .post-card:hover {
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
        }

        .post-top {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .post-avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #7c6aff, #ff6b47);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            color: white;
            flex-shrink: 0;
            overflow : hidden;
        }

        .post-meta h4 {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .post-meta span {
            font-size: 11px;
            color: var(--muted);
        }

        .post-content {
            font-size: 14px;
            line-height: 1.7;
            color: rgba(240, 237, 232, 0.85);
            flex: 1;
            word-break: break-word;
        }

        .post-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 14px;
            border-top: 1px solid var(--border);
        }

        .like-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 7px 14px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            border: 1px solid var(--border);
            color: var(--muted);
        }

        .like-btn:hover {
            color: #ff6b47;
            border-color: rgba(255, 107, 71, 0.3);
            background: rgba(255, 107, 71, 0.06);
        }

        .like-btn.liked {
            color: #ff6b47;
            border-color: rgba(255, 107, 71, 0.3);
            background: rgba(255, 107, 71, 0.08);
        }

        .like-btn svg {
            width: 14px;
            height: 14px;
        }

        .like-count {
            font-size: 12px;
            color: var(--muted);
            font-weight: 500;
        }

        .edit-btn {
            padding: 7px 14px;
            background: none;
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .edit-btn:hover {
            color: var(--accent);
            border-color: rgba(232, 255, 71, 0.3);
            background: rgba(232, 255, 71, 0.04);
        }

        .action-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ── EMPTY STATE ── */
        .empty-state {
            grid-column: 1/-1;
            text-align: center;
            padding: 80px 20px;
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
        }

        .empty-state h3 {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 14px;
            color: var(--muted);
        }

        @media (max-width: 640px) {
            .navbar {
                padding: 0 20px;
            }

            .nav-center {
                display: none;
            }

            .main {
                padding: 32px 20px;
            }

            .posts-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <!-- NAVBAR (same) -->
    <nav class="navbar">
        <a href="/feed" class="nav-brand">
            <div class="nav-dot">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#0a0a0f">
                    <path d="M8 2L10.5 7H14L11 10L12.5 14L8 11.5L3.5 14L5 10L2 7H5.5L8 2Z" />
                </svg>
            </div>
            <span class="nav-name">ᘔEᑎᐯYᖇᗩ</span>
        </a>

        <div class="nav-center">
            <a href="/feed" class="nav-link <%= activePage === 'feed' ? 'active' : '' %>">Feed</a>
            <a href="/profile" class="nav-link <%= activePage === 'profile' ? 'active' : '' %>">My Posts</a>
        </div>

        <div class="nav-right">
            <a href="/profile/upload">
                <div class="avatar">
                    <img class="object-cover w-full h-full" src="/images/uploads/<%= user.profilepic %>" alt="">
                </div>
            </a>
            <a href="/logout" class="logout-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>Logout</a>
        </div>
    </nav>

    <!-- MAIN -->
    <main class="main">

        <!-- COMPOSE (same as profile) -->
        <section class="compose-section">
            <div class="compose-header">
                <h1>Hey, <span>
                        <%= user.name.split(' ')[0] %></span> 👋</h1>
            <p>What' s on your mind today?</p>
            </div>

            <div class="compose-card">
                <form action="/post" method="post">
                    <div class="compose-top">
                        <div class="compose-avatar">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                        <textarea name="content" placeholder="Share a thought, a story, an idea..." required></textarea>
                    </div>

                    <div class="compose-bottom">
                        <span class="compose-meta">@<%= user.username %></span>
                        <button type="submit" class="post-btn">Publish →</button>
                    </div>
                </form>
            </div>
        </section>

        <!-- FEED POSTS -->
        <section>
            <div class="posts-header">
                <h2>Global Feed</h2>
                <span class="posts-count">
                    <%= posts.length %> posts
                </span>
            </div>

            <div class="posts-grid">

                <% if(posts.length===0) { %>
                    <div class="empty-state">
                        <h3>No posts yet</h3>
                    </div>
                    <% } else { %>

                        <% posts.forEach((post, i)=> { %>
                            <div class="post-card">

                                <!-- USER INFO -->
                                <div class="post-top">
                                    <div class="post-avatar">
                                        <img class="object-cover w-full h-full" src="/images/uploads/<%= post.user.profilepic %>" alt="">
                                    </div>

                                    <div class="post-meta">
                                        <h4>@<%= post.user.username %>
                                        </h4>
                                        <span>
                                            <%= new Date(post.date).toDateString() %>
                                        </span>
                                    </div>
                                </div>

                                <!-- CONTENT -->
                                <p class="post-content">
                                    <%= post.content %>
                                </p>

                                <!-- ACTIONS -->
                                <div class="post-footer">
                                    <div class="action-group">

                                        <a href="/like/<%= post._id %>" class="like-btn <%= post.likes && post.likes.indexOf(user._id.toString()) !== -1 ? 'liked' : '' %>">
                                        <svg viewBox="0 0 24 24" fill="<%= post.likes && post.likes.indexOf(user._id.toString()) !== -1 ? '#ff6b47' : 'none' %>" stroke="currentColor" stroke-width="2">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                        </svg>
                                        <%= post.likes && post.likes.indexOf(user._id.toString()) !== -1 ? 'Unlike' : 'Like' %>
                                    </a>
                                    <span class="like-count"><%= post.likes ? post.likes.length : 0 %></span>

                                    </div>

                                    <!-- EDIT ONLY IF OWNER -->
                                    <% if(post.user._id.toString()===user._id.toString()) { %>
                                        <a href="/edit/<%= post._id %>" class="edit-btn">
                                            Edit
                                        </a>
                                        <% } %>

                                </div>

                            </div>
                            <% }) %>

                                <% } %>

            </div>
        </section>

    </main>

</body>

</html>